/**
 * @param {number[]} nums
 * @param {number} k
 * @return {number}
 */
var findMaxAverage = function(nums, k) {
    var sum = 0
    var maxSum = 0

    for(var i = 0; i < k ;i++)
    {
      sum += nums[i]
    }
    maxSum = sum/k

    for(var i = k; i < nums.length;i++)
    {
        sum += nums[i]
        sum -= nums[i-k]
        maxSum = Math.max(maxSum, sum/k)
    }
    return maxSum;
};

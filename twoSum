/**
 * @param {number[]} numbers
 * @param {number} target
 * @return {number[]}
 */
var twoSum = function(numbers, target) {
    var left = 0
    var right = numbers.length - 1;
    let sum = 0
    
    while(left < right)
    {
         sum = numbers[left] + numbers[right];

        if (sum < target) {
            left++;
        } else if (sum > target) {
            right--;
        } else {
            return [left + 1, right + 1];
        }
    }    
};
